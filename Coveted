<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Desert Adventure</title>
    <script src="https://cdn.jsdelivr.net/npm/phaser@3.60.0/dist/phaser.js"></script>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>Desert Adventure</h1>
    <div id="game-container"></div>
    <script src="game.js"></script>
const config = {
    type: Phaser.AUTO,
    width: 800,
    height: 600,
    parent: 'game-container',
    physics: {
        default: 'arcade',
        arcade: { debug: false }
    },
    scene: {
        preload: preload,
        create: create,
        update: update
    }
};

const game = new Phaser.Game(config);

let hero;
let cursors;
let enemy;
let riddleSolved = false;

function preload() {
    this.load.image('desert', 'assets/desert.png');
    this.load.image('hero', 'assets/hero.png');
    this.load.image('enemy', 'assets/enemy.png');
}

function create() {
    this.add.image(400, 300, 'desert');

    hero = this.physics.add.sprite(100, 500, 'hero');
    hero.setCollideWorldBounds(true);

    enemy = this.physics.add.sprite(600, 500, 'enemy');
    enemy.setCollideWorldBounds(true);

    cursors = this.input.keyboard.createCursorKeys();

    // Collision detection
    this.physics.add.overlap(hero, enemy, encounterEnemy, null, this);

    // Simple dialogue
    this.add.text(20, 20, "Your friend disappeared while on a quest to comes to grips with her past and unravel the mystery of her father's assasination...", { font: "18px Arial", fill: "#000" });

    // Riddle
    setTimeout(() => {
        const answer = prompt("Riddle: I speak without a mouth and hear without ears. What am I?");
        if (answer.toLowerCase() === "echo") {
            alert("Correct! You solved the riddle!");
            riddleSolved = true;
        } else {
            alert("Wrong! Try again later.");
        }
    }, 1000);
}

function update() {
    hero.setVelocity(0);

    if (cursors.left.isDown) hero.setVelocityX(-200);
    if (cursors.right.isDown) hero.setVelocityX(200);
    if (cursors.up.isDown) hero.setVelocityY(-200);
    if (cursors.down.isDown) hero.setVelocityY(200);
}

function encounterEnemy(hero, enemy) {
    if (!riddleSolved) {
        alert("Which sloping undersides did the ads cover!");
    } else {
        alert("You defeat the desert raider! Onward to your journey...");
        enemy.destroy();
    }
}

</body>
</html>
